# Or direct psql if tunnel is up:psql -h 127.0.0.1 -U postgres -d omega_bank -c "SELECT     a.owner_name,    w.id as wallet_id,    w.available_balance,    w.settled_balance,    w.currency,    a.account_type,    w.statusFROM wallets wLEFT JOIN accounts a ON a.account_id = w.account_idORDER BY w.available_balance DESC NULLS LAST;psql -h 127.0.0.1 -U postgres -d omega_bank -c "SELECT     COALESCE(a.owner_name, 'Unknown') as owner_name,    w.id as wallet_id,    w.available_balance,    w.settled_balance,    w.currency,    a.account_type,    w.statusFROM wallets wLEFT JOIN accounts a ON a.account_id = w.account_idORDER BY w.available_balance DESC NULLS LAST;"
\q
