#!/usr/bin/env python3
"""
OMEGA PROVENANCE API — Simple & Reliable
"""

from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import parse_qs, urlparse
import json, sqlite3, hashlib
from pathlib import Path

class Handler(BaseHTTPRequestHandler):
    def do_GET(self):
        path = urlparse(self.path)
        
        if path.path == '/health':
            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            self.wfile.write(json.dumps({"status": "online", "collections": 4}).encode())
            return

        if path.path == '/verify':
            q = parse_qs(path.query).get('q', [''])[0]
            result = self.search_ledger(q)
            
            self.send_response(200)
            self.send_header('Content-type', 'application/json')
            self.send_header('Access-Control-Allow-Origin', '*')
            self.end_headers()
            self.wfile.write(json.dumps(result, indent=2).encode())
            return

        self.send_response(404)
        self.end_headers()
        self.wfile.write(b'Not Found')

    def search_ledger(self, q):
        if not q:
            return {"authentic": False, "error": "No query"}
        
        for db_name in ["omega_ledger_2.db", "omega_ledger.db", "omega_ledger_1.db"]:
            db_path = Path.home() / db_name
            if not db_path.exists():
                continue
            try:
                conn = sqlite3.connect(str(db_path))
                cur = conn.cursor()
                cur.execute("SELECT * FROM ledger_events WHERE data LIKE ? LIMIT 3", (f"%{q}%",))
                rows = cur.fetchall()
                if rows:
                    return {"authentic": True, "query": q, "source": db_name, "matches": len(rows)}
                conn.close()
            except:
                continue
        return {"authentic": False, "query": q, "message": "No matching record found"}

if __name__ == "__main__":
    port = 8082
    print(f"🚀 Omega Provenance API running on http://127.0.0.1:{port}")
    HTTPServer(('127.0.0.1', port), Handler).serve_forever()
