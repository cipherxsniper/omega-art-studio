#!/usr/bin/env python3
"""
OMEGA RESTART TRACKER
Parses guardian.log for RESTART events, counts per-process,
flags processes with high restart counts (instability signal).
"""
import re
import os
from collections import Counter
from datetime import datetime, timedelta

LOG_PATH = os.path.expanduser("~/omega_runtime/logs/guardian.log")

def parse_restarts():
    if not os.path.exists(LOG_PATH):
        return {}, []

    pattern = re.compile(r"\[(.*?)\]\s*RESTART:\s*(.+)")
    counts = Counter()
    recent = []

    with open(LOG_PATH) as f:
        for line in f:
            m = pattern.search(line)
            if m:
                timestamp_str, process = m.group(1), m.group(2).strip()
                counts[process] += 1
                recent.append((timestamp_str, process))

    return counts, recent

def report():
    counts, recent = parse_restarts()

    if not counts:
        print("No restart events found in guardian.log")
        return counts

    print("=" * 56)
    print("  OMEGA RESTART TRACKER")
    print("=" * 56)

    for process, count in sorted(counts.items(), key=lambda x: -x[1]):
        flag = ""
        if count >= 10:
            flag = "  ⚠️  UNSTABLE"
        elif count >= 5:
            flag = "  ⚠️  watch"
        print(f"  {process:30} {count:4} restarts{flag}")

    print("=" * 56)
    print(f"  Total restart events logged: {sum(counts.values())}")
    print("=" * 56)

    return counts

if __name__ == "__main__":
    report()
